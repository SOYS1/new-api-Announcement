        const target = eventTargetElement(e);
        if (!target) return;

        if (target.getAttribute("data-action") === "close") {
          close();
          return;
        }

        const opt = target.closest("button[data-value]");
        if (!opt || !onActionModalSelect) return;

        const value = opt.getAttribute("data-value") || "";
        const callback = onActionModalSelect;
        close();

        Promise.resolve(callback(value)).catch((err) => {
          const msg = err instanceof Error ? err.message : String(err);
