    actionEls.importFile?.addEventListener("change", async (e) => {
      const input = e.target;
      if (!(input instanceof HTMLInputElement)) return;
      const file = input.files?.[0];
      input.value = "";
      if (!file) return;

      try {
        const text = await file.text();
        const name = (file.name || "").toLowerCase();

        let nextState = null;
        if (name.endsWith(".json") || text.trim().startsWith("{")) {
          nextState = normalizeState(JSON.parse(text));
        } else if (name.endsWith(".html") || /<\s*html\b/i.test(text) || /\b<!doctype\b/i.test(text)) {
          nextState = parseExportedHtml(text);
          if (!nextState) throw new Error("闂備礁鎼崯鐗堟叏閻㈠灚鍏滈柛鎾茬劍鐎氭岸鏌涢埄鍐炬當闁绘帒銈搁弻?HTML闂備焦瀵х粙鎴︽偋閸℃瑧纾介柟鎹愬煐婵吋銇勯弮鍌楁嫛闁搞們鍊濋弻娑滅疀鐎ｎ亜濮曞┑鐘亾闁哄顑欓崯鍛存煏婢跺牆鍔氱€电増妫冮幃妤呮偨闂堟稑浠橀梺鎼炲€ら崣鍐箚?HTML闂?);
