    actionEls = {
      sample: $("btnSample"),
      reset: $("btnReset"),
      import: $("btnImport"),
      importFile: $("fileImport"),
      copy: $("btnCopy"),
      export: $("btnExport"),
      print: $("btnPrint"),
      addStory: $("btnAddStory"),
