      count: $("aiCount"),
      baseUrl: $("aiBaseUrl"),
      model: $("aiModel"),
      apiKey: $("aiApiKey"),
      remember: $("aiRemember"),
    };
    actionModalEls = {
      root: $("actionModal"),
